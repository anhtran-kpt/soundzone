generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ArtistRole {
  PRIMARY
  FEATURING
}

enum ReleaseType {
  ALBUM
  EP
  SINGLE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  avatarUrl String?
  role      UserRole @default(USER)

  /// Auth flows
  emailVerified             Boolean        @default(false)
  emailVerifiedAt           DateTime?
  passwordResetToken        String?
  passwordResetTokenExpires DateTime?
  refreshTokens             RefreshToken[]

  /// Relations
  playlists        Playlist[]
  favoredSongs     SongFavor[]
  favoredPlaylists PlaylistFavor[]
  favoredAlbums    AlbumFavor[]
  followedArtists  ArtistFollow[]
  playHistory      PlayHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Artist {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  from      String?
  born      DateTime?
  genre     String?
  bio       String?
  avatarUrl String?

  albums      Album[]
  songArtists SongArtist[]
  followers   ArtistFollow[]

  followerCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Album {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String?
  coverUrl    String?
  releaseDate DateTime
  releaseType ReleaseType @default(SINGLE)

  artist   Artist @relation(fields: [artistId], references: [id])
  artistId String

  songs     Song[]
  favoredBy AlbumFavor[]

  songCount     Int @default(0)
  likeCount     Int @default(0)
  totalDuration Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}

model Genre {
  id    String @id @default(cuid())
  name  String @unique
  songs Song[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Song {
  id       String  @id @default(cuid())
  title    String
  slug     String  @unique
  duration Int
  audioUrl String
  coverUrl String?

  album   Album  @relation(fields: [albumId], references: [id])
  albumId String

  genre   Genre  @relation(fields: [genreId], references: [id])
  genreId String

  songArtists   SongArtist[]
  playlistSongs PlaylistSong[]
  favorSongs    SongFavor[]
  playHistory   PlayHistory[]

  favorCount Int @default(0)
  playCount  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}

model SongArtist {
  id       String     @id @default(cuid())
  song     Song       @relation(fields: [songId], references: [id])
  songId   String
  artist   Artist     @relation(fields: [artistId], references: [id])
  artistId String
  role     ArtistRole @default(PRIMARY)
  addedAt  DateTime   @default(now())

  @@unique([songId, artistId])
  @@index([artistId])
}

model Playlist {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  coverUrl    String?
  isPublic    Boolean @default(true)

  user   User   @relation(fields: [userId], references: [id])
  userId String

  songs     PlaylistSong[]
  favoredBy PlaylistFavor[]

  songCount     Int @default(0)
  favorCount    Int @default(0)
  totalDuration Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PlaylistSong {
  id         String   @id @default(cuid())
  playlist   Playlist @relation(fields: [playlistId], references: [id])
  playlistId String
  song       Song     @relation(fields: [songId], references: [id])
  songId     String
  order      Int
  addedAt    DateTime @default(now())

  @@unique([playlistId, songId])
  @@index([playlistId, order])
}

model SongFavor {
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  song      Song     @relation(fields: [songId], references: [id])
  songId    String
  createdAt DateTime @default(now())

  @@id([userId, songId])
}

model AlbumFavor {
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  album     Album    @relation(fields: [albumId], references: [id])
  albumId   String
  createdAt DateTime @default(now())

  @@id([userId, albumId])
}

model PlaylistFavor {
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  playlist   Playlist @relation(fields: [playlistId], references: [id])
  playlistId String
  createdAt  DateTime @default(now())

  @@id([userId, playlistId])
}

model ArtistFollow {
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  artist    Artist   @relation(fields: [artistId], references: [id])
  artistId  String
  createdAt DateTime @default(now())

  @@id([userId, artistId])
}

model PlayHistory {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  song     Song     @relation(fields: [songId], references: [id])
  songId   String
  playedAt DateTime @default(now())

  @@index([userId])
  @@index([songId])
}
